# Set default behavior in case people don't have core.autocrlf set.
* text=auto

# Declare files that must always be treated as binary
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.apk binary
*.aar binary
*.so binary
*.bin binary
*.keystore binary

# Ensure gradlew uses LF line endings
gradlew text eol=lf
gradlew.bat text eol=crlf
